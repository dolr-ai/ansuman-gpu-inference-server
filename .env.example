APP_ENV=local
LOG_LEVEL=INFO
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/gpu_inference
REDIS_URL=redis://localhost:6379/0
RATE_LIMIT_RPM=60
CONCURRENT_REQUEST_LIMIT=4
TOKEN_LIMIT_TPM=60000
MAX_INPUT_TOKENS=8192
MAX_OUTPUT_TOKENS=2048
MAX_TOTAL_TOKENS=10240
CLICKHOUSE_URL=http://localhost:8123
CLICKHOUSE_DATABASE=yral
CLICKHOUSE_USER=gpu_inference
CLICKHOUSE_PASSWORD=
CLICKHOUSE_SECURE=false
CLICKHOUSE_VERIFY=true
CLICKHOUSE_CLUSTER=default
ANALYTICS_QUEUE_SIZE=1000
ANALYTICS_FLUSH_BATCH_SIZE=500
VLLM_BASE_URL=http://127.0.0.1:8001
VLLM_HOST=127.0.0.1
VLLM_PORT=8001
VLLM_MODEL_PATH=Qwen/Qwen3-8B-FP8
VLLM_SERVED_MODEL_NAME=Qwen/Qwen3-8B-FP8
VLLM_TENSOR_PARALLEL_SIZE=4
VLLM_MAX_MODEL_LEN=8192
VLLM_GPU_MEMORY_UTILIZATION=0.9
VLLM_MAX_NUM_SEQS=64
VLLM_MAX_NUM_BATCHED_TOKENS=8192
VLLM_STARTUP_TIMEOUT_SECONDS=900
MODEL_IDS=Qwen/Qwen3-8B-FP8
API_KEY_PREFIX=an
SENTRY_DSN=
SENTRY_SEND_DEFAULT_PII=false
SENTRY_TRACES_SAMPLE_RATE=0.05
