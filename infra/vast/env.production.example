APP_ENV=production
LOG_LEVEL=INFO

APP_DIR=/app
APP_HOST=0.0.0.0
APP_PORT=8000
PUBLIC_BASE_URL=https://model.ansuman.yral.com

# The gateway must call vLLM on a private local port. Do not use port 8000 here.
VLLM_HOST=127.0.0.1
VLLM_PORT=8001
VLLM_BASE_URL=http://127.0.0.1:8001
VLLM_MODEL=
VLLM_ARGS=--gpu-memory-utilization 0.90
RUN_VLLM=1

# Cloudflare Tunnel token for model.ansuman.yral.com. Do not commit the real token.
RUN_CLOUDFLARED=1
CLOUDFLARE_TUNNEL_TOKEN=

# Redis is optional until rate limits and batch queues are implemented.
RUN_REDIS=0
REDIS_URL=redis://127.0.0.1:6379/0

# External services for later implementation phases.
DATABASE_URL=
CLICKHOUSE_URL=
CLICKHOUSE_USER=
CLICKHOUSE_PASSWORD=
SENTRY_DSN=

API_KEY_PREFIX=gib
